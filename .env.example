# ─── TRENDZ Backend Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real credentials.

# Port for the local backend server (default: 3001)
PORT=3001

# ─── Pinterest Trends API ─────────────────────────────────────────────────────
# Get a long-lived access token:
#   1. Go to https://developers.pinterest.com/apps/ → Create app
#   2. Add "Trends" scope
#   3. Complete OAuth2 flow to get an access token
#   4. Paste it here
PINTEREST_ACCESS_TOKEN=

# ─── Apify (TikTok scraper) ───────────────────────────────────────────────────
# Used by the frontend directly (stored in browser localStorage, not here).
# Get a free API key at https://apify.com → Settings → Integrations → API tokens
# Enter it in the dashboard Settings modal (gear icon).
# APIFY_API_KEY=   ← frontend only, not needed here

# ─── Product Image Search ────────────────────────────────────────────────────
# At least one key enables /api/image-search to resolve product-relevant images
# for trends sourced from Amazon, Pinterest, or Google (which don't carry images).
# Pexels is checked first, then Unsplash. If neither is set, images gracefully
# fall back to the category icon.
#
# Pexels — free at https://www.pexels.com/api/ (200 requests/hour)
PEXELS_API_KEY=
#
# Unsplash — free at https://unsplash.com/developers (50 requests/hour)
UNSPLASH_ACCESS_KEY=

# ─── Shopify (one-click launch) ──────────────────────────────────────────────
# Optional server-side defaults. Users can also enter these in the Settings modal.
SHOPIFY_SHOP_DOMAIN=
SHOPIFY_ADMIN_TOKEN=

# ─── AI Copy Generation (Claude) ─────────────────────────────────────────────
# Get an API key at https://console.anthropic.com
# Powers the "Generate Copy" tab in product drawers.
ANTHROPIC_API_KEY=
# Optionally override the Claude model (default: claude-opus-4-7)
ANTHROPIC_CLAUDE_MODEL=

# ─── Dropship Supplier Auto-Match ────────────────────────────────────────────
# At least one supplier source is needed for the Suppliers tab in product drawers.
#
# CJDropshipping — free account at https://cjdropshipping.com
# RATE LIMIT: 10k API calls/day on free tier
CJDROPSHIPPING_EMAIL=
CJDROPSHIPPING_PASSWORD=
#
# AliExpress Affiliate API — register at https://portals.aliexpress.com
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=

# ─── Notes ───────────────────────────────────────────────────────────────────
# Google Trends: uses RSS feed as primary source, no API key required.
# Amazon Movers & Shakers: scraped without auth — no key needed.
# Google Shopping (competitor search): HTML scrape, may trigger CAPTCHAs under load.
