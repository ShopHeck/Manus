# ─── TRENDZ Backend Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real credentials.

# Port for the local backend server (default: 3001)
PORT=3001

# ─── Pinterest Trends API ─────────────────────────────────────────────────────
# Get a long-lived access token:
#   1. Go to https://developers.pinterest.com/apps/ → Create app
#   2. Add "Trends" scope
#   3. Complete OAuth2 flow to get an access token
#   4. Paste it here
PINTEREST_ACCESS_TOKEN=

# ─── Apify (TikTok scraper) ───────────────────────────────────────────────────
# Used by the frontend directly (stored in browser localStorage, not here).
# Get a free API key at https://apify.com → Settings → Integrations → API tokens
# Enter it in the dashboard Settings modal (gear icon).
# APIFY_API_KEY=   ← frontend only, not needed here

# ─── Product Image Search ─────────────────────────────────────────────────────
# At least one key enables /api/image-search to resolve product images.
# Pexels is checked first, then Unsplash. If neither is set images fall back
# to the category icon.
#
# Pexels — free at https://www.pexels.com/api/ (200 req/hour)
PEXELS_API_KEY=
#
# Unsplash — free at https://unsplash.com/developers (50 req/hour)
UNSPLASH_ACCESS_KEY=

# ─── AI Copy Generation (Claude) ─────────────────────────────────────────────
# Required for the "Copy" tab in the product drawer.
# Get your key at https://console.anthropic.com → API Keys
# RISK: Each generation costs ~$0.01-0.05 depending on model.
ANTHROPIC_API_KEY=
#
# Model to use for copy generation. Defaults to claude-opus-4-7 (highest quality).
# Use claude-sonnet-4-6 for faster / cheaper generation.
ANTHROPIC_CLAUDE_MODEL=claude-opus-4-7

# ─── Supplier Auto-Match: CJDropshipping ─────────────────────────────────────
# Required for CJDropshipping supplier lookup (/api/suppliers/search).
# Register at https://cjdropshipping.com → Developer → API Access
# The backend authenticates via email + password and caches the token for 23 h.
CJDROPSHIPPING_EMAIL=
CJDROPSHIPPING_PASSWORD=

# ─── Supplier Auto-Match: AliExpress ─────────────────────────────────────────
# Required for AliExpress supplier lookup (/api/suppliers/search).
# Register at https://portals.aliexpress.com → Affiliate → Open Platform
# Requires APP_KEY (Application ID) and APP_SECRET for HMAC-SHA256 signing.
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=

# ─── Notes ───────────────────────────────────────────────────────────────────
# Google Trends, Amazon Movers & Shakers, and Google Shopping competitor search
# require no API keys — they are scraped server-side to avoid CORS and bot detection.
#
# RATE-LIMIT RISKS:
#   - Google Shopping (/api/competitors/search) is unauthenticated HTML scraping.
#     Under heavy load Google may return CAPTCHAs or 429s. Consider caching
#     competitor results in Redis or a similar store in production.
#   - Amazon (/api/amazon-movers) may block IPs after many rapid requests.
#     Add a 2-5 second delay between requests if running automated pipelines.
#   - Reddit public JSON is generous but may rate-limit at ~100 req/min per IP.
